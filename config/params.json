{
    "log_level": "DEBUG",
    "log_file":  "",

    "mavsdk": {
        "connection_url":          "udpin://0.0.0.0:14540",
        "connect_timeout_s":       30.0,
        "attitude_rate_hz":        100.0,
        "velocity_rate_hz":        50.0,
        "status_rate_hz":          10.0,
        "enable_debug_sniffer":    true,
        "enable_statustext":       true,
        "debug_dump_interval_s":   5.0
    },

    "camera": {
        "device_index":    0,
        "source_url":      "",
        "width":           640,
        "height":          480,
        "fps":             30,
        "flip_horizontal": false,
        "show_preview":    false
    },

    "detector": {
        "use_background_sub":  false,
        "canny_low":           50,
        "canny_high":          150,
        "blur_kernel":         5,
        "min_area_ratio":      0.005,
        "max_area_ratio":      0.90,
        "left_sector_end":     0.35,
        "right_sector_start":  0.65,
        "draw_debug":          false
    },

    "depth": {
        "window_size":        10,
        "ttc_max_s":          30.0,
        "min_confidence":     0.3,
        "max_approach_slope": 0.5
    },

    "avoidance": {
        "obs_max_age_s":            0.5,

        "k_att":                    3.0,
        "k_rep":                    20.0,
        "k_damp":                   0.3,
        "ttc_influence_s":          10.0,
        "camera_hfov_deg":          60.0,
        "max_speed_m_s":            5.0,
        "ascent_speed_m_s":         1.0,
        "ttc_emergency_s":          1.5,

        "stuck_vel_threshold_m_s":  0.2,
        "stuck_timeout_ticks":      20,
        "stuck_kick_speed_m_s":     0.8
    },

    "pid": {
        "ttc_target_s":              5.0,
        "fwd_kp":                    0.15,
        "fwd_ki":                    0.02,
        "fwd_kd":                    0.05,
        "fwd_max_integral":          2.0,
        "fwd_deriv_tau":             0.15,

        "alt_kp":                    0.8,
        "alt_ki":                    0.05,
        "alt_kd":                    0.2,
        "alt_max_integral":          1.0,
        "alt_max_output_m_s":        1.5,
        "alt_deriv_tau":             0.1,

        "max_delta_speed_per_tick":  0.5,

        "cbf_enabled":               true,
        "cbf_ttc_min_s":             1.5,
        "cbf_gamma":                 1.0,
        "cbf_activate_h":            3.0,
        "camera_hfov_deg":           60.0
    },

    "command": {
        "takeoff_altitude_m":    5.0,
        "offboard_heartbeat_ms": 400.0
    },

    "control": {
        "loop_rate_hz":     5.0,
        "takeoff_alt_m":    5.0,
        "cruising_alt_m":   5.0,
        "alt_reached_tol":  0.5,
        "auto_arm_takeoff": false
    }
}
